{
  "info": {
    "_postman_id": "72ef423f-ba5d-4f54-8afe-191b93cfac86",
    "name": "Slack Stars API",
    "description": "The Slack Stars API is a set of Web API methods that let apps manage a user\u0019s starred items\u0014Slack\u0019s legacy personal bookmarking feature. It allows adding or removing a star on items such as messages (via channel and timestamp), files, and file comments, and listing all items a user has starred, typically with pagination and basic metadata. Stars are user-specific and don\u0019t alter the underlying content; they simply mark things for quick reference. Note that Slack has moved toward Saved items and other mechanisms in the client, and the stars.* methods have been deprecated, so availability and support may be limited.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "createdAt": "2026-06-05T13:19:54.000Z",
    "updatedAt": "2026-06-05T13:19:55.000Z",
    "lastUpdatedBy": "35240",
    "uid": "35240-72ef423f-ba5d-4f54-8afe-191b93cfac86"
  },
