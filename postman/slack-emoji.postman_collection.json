  "info": {
    "_postman_id": "e46a1617-b6e4-49ea-a714-1e2e4294d121",
    "name": "Slack Emoji API",
    "description": "Slack's Emoji API lets apps discover and manage a workspace's custom emoji. The core method, emoji.list (requires the emoji:read scope), returns a name-to-URL map of all custom emoji along with aliases (noted as alias:other_name) and a cache timestamp to help clients sync efficiently. Apps can also subscribe to the emoji_changed event to stay up to date when emoji are added, renamed, or removed.\n\nContact Support:\n Name: Slack Developer Relations",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "createdAt": "2026-06-05T13:19:22.000Z",
    "updatedAt": "2026-06-05T13:19:22.000Z",
    "lastUpdatedBy": "35240",
