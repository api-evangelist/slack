{
  "info": {
    "_postman_id": "d44e1323-3a3b-4b12-bf7c-23c875ddba44",
    "name": "Slack OAuth API",
    "description": "The Slack OAuth API implements the OAuth 2.0 flow that lets developers securely install Slack apps to workspaces and obtain access tokens with specific, granular scopes. An app redirects a user to Slack for consent; after approval, Slack returns an authorization code that the app exchanges for tokens (typically a bot token, and optionally a user token) to call the Web API within the granted permissions. The OAuth system manages scopes, workspace and enterprise installations, admin approvals, reauthorization when scopes change, token rotation with refresh tokens, and revocation when apps are uninstalled or access is removed. For user sign-in, Slack also offers an OpenID Connect\u0013based flow. In short, it provides consent-driven installation, permissioning, and token lifecycle management for Slack apps.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "createdAt": "2026-06-05T13:19:47.000Z",
    "updatedAt": "2026-06-05T13:19:47.000Z",
    "lastUpdatedBy": "35240",
    "uid": "35240-d44e1323-3a3b-4b12-bf7c-23c875ddba44"
  },
