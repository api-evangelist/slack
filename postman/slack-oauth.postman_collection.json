            "url": {
              "raw": "{{baseUrl}}/oauth.access?client_id=<string>&client_secret=<string>&code=<string>&redirect_uri=<string>&single_channel=<boolean>",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "oauth.access"
              ],
              "query": [
                {
                  "description": "Issued when you created your application.",
                  "key": "client_id",
                  "value": "<string>"
                },
                {
                  "description": "Issued when you created your application.",
