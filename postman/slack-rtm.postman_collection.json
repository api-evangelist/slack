{
  "info": {
    "_postman_id": "3027f038-f6f9-492a-bc43-700ecd8e590b",
    "name": "Slack RTM API",
    "description": "The Slack Real Time Messaging (RTM) API lets an app open a WebSocket connection to Slack and receive a live stream of JSON events from a workspace\u0014such as new messages, edits, reactions, user presence and typing indicators, channel joins, and more\u0014so you can build low\u0011latency, interactive bots and clients. Apps typically use the RTM stream for listening and the Web API for performing actions like posting or updating messages. You start by calling rtm.connect (or rtm.start, historically) to obtain a WebSocket URL, then maintain the socket to process events as they happen. RTM is now considered legacy; for new apps Slack recommends using the Events API with the Web API, or Socket Mode if you can\u0019t expose a public HTTP endpoint.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "createdAt": "2026-06-05T13:19:52.000Z",
    "updatedAt": "2026-06-05T13:19:52.000Z",
    "lastUpdatedBy": "35240",
    "uid": "35240-3027f038-f6f9-492a-bc43-700ecd8e590b"
  },
