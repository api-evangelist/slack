{
  "info": {
    "_postman_id": "441c0f37-3b2a-4ef2-91b0-ce36fa41b864",
    "name": "Slack Functions API",
    "description": "The Slack Functions API provides methods for managing custom functions that run as steps within Slack workflows. The key methods are functions.completeSuccess, which marks a custom function as having completed successfully and passes output data conforming to the function's defined output schema, and functions.completeError, which marks a custom function as having failed and passes an error message that surfaces to the end user via Slackbot.\n\nContact Support:\n Name: Slack Developer Relations",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "createdAt": "2026-06-05T13:19:43.000Z",
    "updatedAt": "2026-06-05T13:19:43.000Z",
    "lastUpdatedBy": "35240",
    "uid": "35240-441c0f37-3b2a-4ef2-91b0-ce36fa41b864"
  },
