{
  "info": {
    "_postman_id": "e5f8bf38-a8ba-482d-9768-9a815d2813f8",
    "name": "Slack Pins API",
    "description": "The Slack Pins API is a set of Web API methods that let your app manage pinned items in conversations so important content is easy to find. With pins.add, pins.list, and pins.remove, you can programmatically pin or unpin messages, files, and file comments in channels, private channels, and DMs by providing the conversation ID and the message timestamp or file/comment ID. Pinned items surface in the conversation\u0019s details panel in the Slack client, and pins.list returns the same set so your app can mirror or analyze it. These methods require your app to be a member of the conversation and have appropriate permissions, and they observe Slack\u0019s standard rate limits.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "createdAt": "2026-06-05T13:19:49.000Z",
    "updatedAt": "2026-06-05T13:19:49.000Z",
    "lastUpdatedBy": "35240",
    "uid": "35240-e5f8bf38-a8ba-482d-9768-9a815d2813f8"
  },
