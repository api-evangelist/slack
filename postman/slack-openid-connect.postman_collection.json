        {
          "name": "Exchange OpenID Connect Token",
          "id": "2e333093-2d6b-495c-8004-588b04a68aa2",
          "protocolProfileBehavior": {
            "disableBodyPruning": true
          },
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "description": "(Required) The Slack app's client ID.",
                  "key": "client_id",
                  "value": "<string>"
                },
                {
                  "description": "(Required) The Slack app's client secret.",
                  "key": "client_secret",
                  "value": "<string>"
                },
                {
                  "description": "(Required) The authorization code received from the Sign in with Slack flow.",
                  "key": "code",
                  "value": "<string>"
                },
                {
                  "description": "The redirect URI that was used in the authorization request.",
                  "key": "redirect_uri",
                  "value": "<string>"
                },
                {
                  "description": "The grant type, must be \"authorization_code\".",
                  "key": "grant_type",
                  "value": "authorization_code"
                },
                {
                  "description": "The refresh token, required when grant_type is refresh_token.",
                  "key": "refresh_token",
                  "value": "<string>"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/openid.connect.token",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "openid.connect.token"
              ]
            },
            "description": "Exchanges an authorization code for an OpenID Connect access token and ID token."
          },
