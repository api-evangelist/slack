{
  "info": {
    "_postman_id": "3c034299-84af-4f9e-86a5-91ce32f52ec5",
    "name": "Slack OpenID Connect API",
    "description": "The Slack OpenID Connect API implements the Sign in with Slack flow based on the OpenID Connect standard built on top of OAuth 2.0. It includes openid.connect.token for exchanging an authorization code for an access token and a standard JWT id_token, and openid.connect.userInfo for retrieving identity information about a user who has authenticated via Sign in with Slack.\n\nContact Support:\n Name: Slack Developer Relations",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "createdAt": "2026-06-05T13:19:47.000Z",
    "updatedAt": "2026-06-05T13:19:48.000Z",
    "lastUpdatedBy": "35240",
    "uid": "35240-3c034299-84af-4f9e-86a5-91ce32f52ec5"
  },
