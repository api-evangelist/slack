      "name": "openid.connect.userInfo",
      "item": [
        {
          "name": "Get OpenID Connect User Info",
          "id": "8039c344-c69e-4256-82f5-72b7950057a4",
          "protocolProfileBehavior": {
            "disableBodyPruning": true
          },
          "request": {
            "auth": {
              "type": "oauth2",
              "oauth2": [
                {
                  "key": "scope",
                  "value": "openid email profile",
                  "type": "string"
                },
                {
                  "key": "accessTokenUrl",
                  "value": "https://slack.com/api/openid.connect.token",
                  "type": "string"
                },
                {
                  "key": "authUrl",
                  "value": "https://slack.com/openid/connect/authorize",
                  "type": "string"
                },
                {
                  "key": "grant_type",
                  "value": "authorization_code",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/openid.connect.userInfo?token=<string>",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "openid.connect.userInfo"
              ],
              "query": [
                {
                  "description": "(Required) OpenID Connect access token.",
                  "key": "token",
                  "value": "<string>"
                }
              ]
            },
            "description": "Retrieves identity information about a user authenticated via Sign in with Slack."
          },
