            "name": "Slack Post Users Setactive",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "{{baseUrl}}/users.setActive",
            "headers": [
              {
                "name": "token",
                "value": ""
              }
            ]
          },
          "docs": "Marked a user as active. Deprecated and non-functional."
        },
        {
          "info": {
            "name": "Slack Post Users Setphoto",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "{{baseUrl}}/users.setPhoto",
