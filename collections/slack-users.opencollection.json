          },
          "http": {
            "method": "POST",
            "url": "{{baseUrl}}/users.deletePhoto",
            "body": {
              "type": "form-urlencoded",
              "data": [
                {
                  "name": "token",
                  "value": ""
                }
              ]
            }
          },
          "docs": "Delete the user profile photo"
        },
        {
          "info": {
            "name": "Slack Post Users Profile Set",
            "type": "http"
          },
          "http": {
            "method": "POST",
