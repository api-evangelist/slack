{
  "opencollection": "1.0.0",
  "info": {
    "name": "Slack Web API",
    "version": "1.0.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Auth",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Slack Test Authentication",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://slack.com/api/auth.test"
          },
          "docs": "Checks authentication and tells the caller who they are. Returns information about the token holder including user ID, team ID, and team name."
        },
        {
          "info": {
            "name": "Slack Revoke an Access Token",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://slack.com/api/auth.revoke",
            "params": [
              {
                "name": "test",
                "value": "",
                "type": "query",
                "description": "Setting this parameter to true triggers a testing mode."
              }
            ]
          },
          "docs": "Revokes the access token that is used to call this method."
        }
      ]
    },
    {
      "info": {
        "name": "Chat",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Slack Send a Message to a Channel",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://slack.com/api/chat.postMessage",
            "headers": [
              {
                "name": "token",
                "value": ""
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Sends a message to a channel, DM, or group conversation. Supports plain text, Block Kit layouts, attachments, threading, and message metadata. Requires the chat:write scope, or chat:write.public to post to channels the bot is not a member of."
        },
        {
          "info": {
            "name": "Slack Update an Existing Message",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://slack.com/api/chat.update",
            "headers": [
              {
                "name": "token",
                "value": ""
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Updates a message in a channel. Both the text and blocks can be updated. Requires the chat:write scope."
        },
        {
          "info": {
            "name": "Slack Delete a Message",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://slack.com/api/chat.delete",
            "headers": [
              {
                "name": "token",
                "value": ""
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Deletes a message from a channel. Requires the chat:write scope. The message must have been posted by the calling user or bot."
        },
        {
          "info": {
            "name": "Slack Send an Ephemeral Message",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://slack.com/api/chat.postEphemeral",
            "headers": [
              {
                "name": "token",
                "value": ""
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Sends an ephemeral message to a user in a channel, visible only to that user. Requires the chat:write scope."
        },
        {
          "info": {
            "name": "Slack Schedule a Message for Later",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://slack.com/api/chat.scheduleMessage",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Schedules a message to be sent to a channel at a specified time. Requires the chat:write scope."
        },
        {
          "info": {
            "name": "Slack Get a Permalink for a Message",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://slack.com/api/chat.getPermalink",
            "params": [
              {
                "name": "channel",
                "value": "",
                "type": "query",
                "description": "The ID of the conversation or channel containing the message."
              },
              {
                "name": "message_ts",
                "value": "",
                "type": "query",
                "description": "A message's ts value."
              }
            ]
          },
          "docs": "Retrieve a permalink URL for a specific extant message."
        },
        {
          "info": {
            "name": "Slack Provide Custom Unfurl Behavior",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://slack.com/api/chat.unfurl",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Provide custom unfurl behavior for URLs posted in messages. Requires links:write scope."
        }
      ]
    },
    {
      "info": {
        "name": "Conversations",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Slack List All Channels",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://slack.com/api/conversations.list",
            "params": [
              {
                "name": "cursor",
                "value": "",
                "type": "query",
                "description": "Paginate through collections by setting the cursor parameter to a next_cursor attribute returned by a previous request."
              },
              {
                "name": "exclude_archived",
                "value": "",
                "type": "query",
                "description": "Set to true to exclude archived channels from the list."
              },
              {
                "name": "limit",
                "value": "",
                "type": "query",
                "description": "The maximum number of items to return. Fewer than the requested number of items may be returned, even if the end of the list hasn't been reached. Maximum of 1000."
              },
              {
                "name": "team_id",
                "value": "",
                "type": "query",
                "description": "Required for org-wide app tokens. A single team ID to list channels in."
              },
              {
                "name": "types",
                "value": "",
                "type": "query",
                "description": "Mix and match channel types by providing a comma-separated list. Options: public_channel, private_channel, mpim, im."
              }
            ]
          },
          "docs": "Lists all channels in a Slack team. Returns a paginated collection of conversation objects. Supports filtering by conversation type."
        },
        {
          "info": {
            "name": "Slack Get Information About a Channel",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://slack.com/api/conversations.info",
            "params": [
              {
                "name": "channel",
                "value": "",
                "type": "query",
                "description": "The conversation ID to get info on."
              },
              {
                "name": "include_locale",
                "value": "",
                "type": "query",
                "description": "Set to true to receive the locale for this conversation."
              },
              {
                "name": "include_num_members",
                "value": "",
                "type": "query",
                "description": "Set to true to include the member count."
              }
            ]
          },
          "docs": "Retrieve information about a conversation including its purpose, topic, member count, and other metadata."
        },
        {
          "info": {
            "name": "Slack Fetch Message History",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://slack.com/api/conversations.history",
            "params": [
              {
                "name": "channel",
                "value": "",
                "type": "query",
                "description": "Conversation ID to fetch history for."
              },
              {
                "name": "cursor",
                "value": "",
                "type": "query",
                "description": "Paginate through collections by setting the cursor parameter to a next_cursor attribute returned by a previous request."
              },
              {
                "name": "inclusive",
                "value": "",
                "type": "query",
                "description": "Include messages with oldest or latest timestamps in results."
              },
              {
                "name": "latest",
                "value": "",
                "type": "query",
                "description": "Only messages before this Unix timestamp will be included. Default is the current time."
              },
              {
                "name": "limit",
                "value": "",
                "type": "query",
                "description": "The maximum number of items to return. Default 100, max 999."
              },
              {
                "name": "oldest",
                "value": "",
                "type": "query",
                "description": "Only messages after this Unix timestamp will be included. Default is 0."
              },
              {
                "name": "include_all_metadata",
                "value": "",
                "type": "query",
                "description": "Return all metadata associated with messages."
              }
            ]
          },
          "docs": "Fetches a conversation's history of messages and events. Returns messages in reverse chronological order."
        },
        {
          "info": {
            "name": "Slack Create a Channel",
