  "info": {
    "_postman_id": "4ca856f2-f207-44ca-814c-a6c9f2e4e207",
    "name": "Slack Emoji API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Slack's Emoji API lets apps discover and manage a workspace's custom emoji. The core method, emoji.list (requires the emoji:read scope), returns a name-to-URL map of all custom emoji along with aliases (noted as alias:other_name) and a cache timestamp to help clients sync efficiently. Apps can also subscribe to the emoji_changed event to stay up to date when emoji are added, renamed, or removed.\n\nContact Support:\n Name: Slack Developer Relations",
      "type": "text/plain"
    }
  }
