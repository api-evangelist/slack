{
  "opencollection": "1.0.0",
  "info": {
    "name": "Slack Assistant API",
    "version": "1.0.0"
  },
  "items": [
    {
      "info": {
        "name": "AI",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Set Assistant Thread Status",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://slack.com/api/assistant.threads.setStatus",
            "headers": [
              {
                "name": "token",
                "value": ""
              }
            ],
            "body": {
              "type": "form-urlencoded",
              "data": [
                {
                  "name": "channel_id",
                  "value": ""
                },
                {
                  "name": "thread_ts",
                  "value": ""
                },
                {
                  "name": "status",
                  "value": ""
                }
              ]
            },
            "auth": {
              "type": "oauth2",
              "flow": "authorization_code",
              "authorizationUrl": "https://slack.com/oauth/v2/authorize",
              "accessTokenUrl": "https://slack.com/api/oauth.v2.access",
              "credentials": {
                "clientId": "{{clientId}}",
                "clientSecret": "{{clientSecret}}"
              }
            }
          },
          "docs": "Sets the status of a Slack AI assistant thread, for example showing a thinking indicator."
        },
        {
          "info": {
            "name": "Set Assistant Thread Suggested Prompts",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://slack.com/api/assistant.threads.setSuggestedPrompts",
            "headers": [
              {
                "name": "token",
                "value": ""
              }
            ],
            "body": {
              "type": "form-urlencoded",
              "data": [
                {
                  "name": "channel_id",
                  "value": ""
                },
                {
                  "name": "thread_ts",
                  "value": ""
                },
                {
                  "name": "prompts",
                  "value": ""
                },
                {
                  "name": "title",
                  "value": ""
                }
              ]
            },
            "auth": {
              "type": "oauth2",
              "flow": "authorization_code",
              "authorizationUrl": "https://slack.com/oauth/v2/authorize",
              "accessTokenUrl": "https://slack.com/api/oauth.v2.access",
              "credentials": {
                "clientId": "{{clientId}}",
                "clientSecret": "{{clientSecret}}"
              }
            }
          },
          "docs": "Sets the suggested prompts for a Slack AI assistant thread."
        },
        {
          "info": {
            "name": "Set Assistant Thread Title",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://slack.com/api/assistant.threads.setTitle",
            "headers": [
              {
                "name": "token",
                "value": ""
              }
            ],
            "body": {
              "type": "form-urlencoded",
              "data": [
                {
                  "name": "channel_id",
                  "value": ""
                },
                {
                  "name": "thread_ts",
                  "value": ""
                },
                {
                  "name": "title",
                  "value": ""
                }
              ]
            },
            "auth": {
              "type": "oauth2",
              "flow": "authorization_code",
              "authorizationUrl": "https://slack.com/oauth/v2/authorize",
              "accessTokenUrl": "https://slack.com/api/oauth.v2.access",
              "credentials": {
                "clientId": "{{clientId}}",
                "clientSecret": "{{clientSecret}}"
              }
            }
          },
          "docs": "Sets the title of a Slack AI assistant thread."
