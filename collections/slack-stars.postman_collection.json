  "info": {
    "_postman_id": "405aef22-ad26-4e90-905c-21e69d986ce8",
    "name": "Slack Stars API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Slack Stars API is a set of Web API methods that let apps manage a user\u0019s starred items\u0014Slack\u0019s legacy personal bookmarking feature. It allows adding or removing a star on items such as messages (via channel and timestamp), files, and file comments, and listing all items a user has starred, typically with pagination and basic metadata. Stars are user-specific and don\u0019t alter the underlying content; they simply mark things for quick reference. Note that Slack has moved toward Saved items and other mechanisms in the client, and the stars.* methods have been deprecated, so availability and support may be limited.",
      "type": "text/plain"
    }
  }
